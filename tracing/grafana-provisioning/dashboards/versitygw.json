    {
      "id": 40,
      "type": "timeseries",
      "title": "Middleware p50 Latency (ms)",
      "description": "p50 latency of each middleware span over time. One line per layer \u2014 lets you spot which middleware is slowest or where latency is spiking.",
      "gridPos": {
        "x": 0,
        "y": 41,
        "w": 12,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
